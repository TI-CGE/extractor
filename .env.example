# Copie para .env e preencha os valores locais / CI.
# Nunca commite o arquivo .env com segredos.

# PostgreSQL (warehouse)
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_DB=
# POSTGRES_USER=
# POSTGRES_PASSWORD=

# Airflow
# AIRFLOW_UID=
# AIRFLOW__CORE__FERNET_KEY=
# AIRFLOW__WEBSERVER__SECRET_KEY=

# dbt
# DBT_PROFILES_DIR=

# Fontes (exemplos — ajuste por conector)
# ORACLE_HOST=
# MYSQL_HOST=
